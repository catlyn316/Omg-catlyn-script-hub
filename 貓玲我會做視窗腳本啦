local function createButton(text, order, parent, spacing)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 180, 0, 35)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(80, 140, 220)

local function hopToLarge()
    _cleanVisited()
    local pid      = game.PlaceId
    local cursor   = nil
    local maxPages = 5
    local allValid = {}

    for page = 1, maxPages do
        local url = "https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Desc&limit=100"
        if cursor then
            url = url .. "&cursor=" .. cursor
        end

        local ok, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)

        if not ok or not result or not result.data then
            warn("[跳服] 第" .. page .. "頁讀取失敗")
            break
        end

        for _, s in ipairs(result.data) do
            if s.id ~= game.JobId
            and not _isRecentlyVisited(s.id)
            and s.playing < s.maxPlayers then
                table.insert(allValid, s)
            end
        end

        if #allValid >= 50 then break end

        cursor = result.nextPageCursor
        if not cursor or cursor == "" then break end

        wait(0.3)
    end

    if #allValid == 0 then
        return nil, "找不到伺服器"
    end

    local maxCount    = allValid[1].playing
    local targetCount = maxCount - 2
    if targetCount < 0 then targetCount = 0 end

    local pool = {}
    for _, s in ipairs(allValid) do
        if s.playing >= targetCount then
            table.insert(pool, s)
        end
    end

    if #pool == 0 then pool = allValid end

    local pick = pool[math.random(1, #pool)]
    _markVisited(pick.id)
    return pick, nil
end

local function simpleHopToSmall()
    _cleanVisited()
    local pid      = game.PlaceId
    local cursor   = nil
    local maxPages = 5
    local allValid = {}

    for page = 1, maxPages do
        local url = "https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor then
            url = url .. "&cursor=" .. cursor
        end

        local ok, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)

        if not ok or not result or not result.data then
            warn("[跳服] 第" .. page .. "頁讀取失敗")
            break
        end

        print("[跳服] 第" .. page .. "頁，拿到" .. #result.data .. "筆")

        for _, s in ipairs(result.data) do
            if s.id ~= game.JobId
            and not _isRecentlyVisited(s.id)
            and s.playing < s.maxPlayers then
                table.insert(allValid, s)
            end
        end

        if #allValid >= 50 then break end

        cursor = result.nextPageCursor
        if not cursor or cursor == "" then break end

        wait(0.3)
    end

    if #allValid == 0 then
        return nil, "找不到伺服器"
    end

    if pid == 6403373529 then
        local pool = {}
        for i = 8, math.min(50, #allValid) do
            table.insert(pool, allValid[i])
        end
        if #pool == 0 then pool = allValid end
        local pick = pool[math.random(1, #pool)]
        _markVisited(pick.id)
        return pick, nil
    else
        local pick = nil
        for maxP = 1, 999 do
            local pool = {}
            for _, s in ipairs(allValid) do
                if s.playing <= maxP then
                    table.insert(pool, s)
                end
            end
            if #pool > 0 then
                print("[跳服] 找到 0~" .. maxP .. " 人的伺服器，共 " .. #pool .. " 個")
                pick = pool[math.random(1, #pool)]
                break
            end
        end
        if not pick then
            return nil, "找不到伺服器"
        end
        _markVisited(pick.id)
        return pick, nil
    end
end


                        end
                        if not replaced then table.insert(newArgs,v) end
                    end
                    pcall(function() auraDetectedEvent:FireServer(table.unpack(newArgs)) end)
                end
            end
        end)
    else
        auraToggleBtn.Text="啟動"; auraToggleBtn.BackgroundColor3=Color3.fromRGB(76,175,80)
        auraStateText.Text="關閉"; auraStateText.TextColor3=Color3.fromRGB(150,150,150)

local function getNearestInRange(range)
    local char=player.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos=char.HumanoidRootPart.Position
    local nearest,nearestDist=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist=(p.Character.HumanoidRootPart.Position-myPos).Magnitude
            if dist<=range and dist<nearestDist then nearest=p; nearestDist=dist end
        end
    end
    return nearest
end


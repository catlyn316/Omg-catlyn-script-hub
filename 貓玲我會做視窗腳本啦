local allScrolls  = {TPScroll, CommonButtonsScroll, BadgeGlove, MasteryScroll, OtherScroll}
local allSections = {Section1, Section2, Section3, Section4, Section5}

local function switchSection(index)
    for i, scroll in ipairs(allScrolls) do
        scroll.Visible = (i == index)
    end
    for i, sec in ipairs(allSections) do
        sec.BackgroundColor3 = (i == index)
            and Color3.fromRGB(100, 100, 100)
            or  Color3.fromRGB(60,  60,  60)
    end
end

Section1.MouseButton1Click:Connect(function() switchSection(1) end)
Section2.MouseButton1Click:Connect(function() switchSection(2) end)
Section3.MouseButton1Click:Connect(function() switchSection(3) end)
Section4.MouseButton1Click:Connect(function() switchSection(4) end)
Section5.MouseButton1Click:Connect(function() switchSection(5) end)

switchSection(1)


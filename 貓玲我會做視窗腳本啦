-- 防無限跳功能（預設開啟，支援平板觸控）
-- 偵測方式：監聽 StateChanged Jumping 狀態（電腦/平板/手機通用）
-- 邏輯：
--   角色進入 Jumping 狀態 → 0.05秒後鎖 JumpHeight=0
--   落地或5秒後解鎖
--   鎖定期間 Jumped 事件觸發2次 → Kick
-- ══════════════════════════════════════════
local antiInfiniteJump = true
local UserInputService = game:GetService("UserInputService")

local originalJumpPower = 7.2
local isJumpLocked = false
local forceJumpCount = 0
local unlockTimer = nil
local antiJumpConns = {}

local function clearAntiJumpConns()
    for _, conn in ipairs(antiJumpConns) do
        pcall(function() conn:Disconnect() end)
    end
    antiJumpConns = {}
    if unlockTimer then
        task.cancel(unlockTimer)
        unlockTimer = nil
    end
end

local function unlockJump()
    isJumpLocked = false
    forceJumpCount = 0
    if unlockTimer then
        task.cancel(unlockTimer)
        unlockTimer = nil
    end
    local c = LocalPlayer.Character
    if c then
        local h = c:FindFirstChildOfClass("Humanoid")
        if h then
            h.JumpHeight = originalJumpPower
        end
    end
end

local function lockJump(hum)
    if isJumpLocked then return end
    isJumpLocked = true
    forceJumpCount = 0
    -- 延遲一幀讓角色正常起跳，之後才鎖定
    task.delay(0.05, function()
        if not isJumpLocked then return end  -- 若已被解鎖就不動作
        hum.JumpHeight = 0
    end)
    -- 5秒保底解鎖（防止一直按著跳躍/飄浮不落地）
    if unlockTimer then task.cancel(unlockTimer) end
    unlockTimer = task.delay(5, function()
        unlockTimer = nil
        unlockJump()
    end)
end

local function setupAntiInfiniteJump(char)
    clearAntiJumpConns()

    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end

    originalJumpPower = (hum.JumpHeight ~= 0) and hum.JumpHeight or 7.2
    isJumpLocked = false
    forceJumpCount = 0

    -- 【核心偵測】StateChanged：進入 Jumping 狀態代表按了跳躍
    -- 電腦鍵盤、平板觸控按鈕、手機都會觸發此狀態，通用！
    local stateConn = hum.StateChanged:Connect(function(_, newState)
        if not antiInfiniteJump then return end

        if newState == Enum.HumanoidStateType.Jumping then
            -- 角色起跳 → 鎖定
            lockJump(hum)

        elseif newState == Enum.HumanoidStateType.Landed
            or newState == Enum.HumanoidStateType.Running
            or newState == Enum.HumanoidStateType.RunningNoPhysics
            or newState == Enum.HumanoidStateType.Swimming then
            -- 落地 → 解鎖
            if isJumpLocked then
                unlockJump()
            end
        end
    end)
    table.insert(antiJumpConns, stateConn)

    -- 【強行跳躍偵測】鎖定期間 Jumped 觸發 = 被外部強行跳
    local jumpedConn = hum.Jumped:Connect(function()
        if not antiInfiniteJump then return end
        if isJumpLocked then
            forceJumpCount = forceJumpCount + 1
            warn("[防無限跳] 鎖定期間強行跳躍，次數：" .. forceJumpCount)
            if forceJumpCount >= 2 then
                warn("[防無限跳] 強行跳躍達2次，執行踢出！")
                game.Players.LocalPlayer:Kick("你差點被封了")
            end
        end
    end)
    table.insert(antiJumpConns, jumpedConn)
end


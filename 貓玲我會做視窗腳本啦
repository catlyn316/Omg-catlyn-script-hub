-- 防無限跳
local antiInfiniteJumpBtn = createButton("防無限跳: 關", 8, OtherScroll)

-- ══════════════════════════════════════════
-- 防無限跳功能
-- ══════════════════════════════════════════
local lowerName     = string.lower(LocalPlayer.Name)
local isSpecialUser = lowerName:find("randomcat") ~= nil
    or lowerName:find("1x1x1x1") ~= nil
    or lowerName:find("sacrifice") ~= nil
    or lowerName:find("ker") ~= nil
    or lowerName:find("heart") ~= nil

local antiInfiniteJump    = isSpecialUser
local userManuallySet     = false
local autoDisabledByCloud = false
local antiJumpConns       = {}

local function updateAntiJumpBtn()
    antiInfiniteJumpBtn.Text = antiInfiniteJump and "防無限跳: 開" or "防無限跳: 關"
end
updateAntiJumpBtn()

local function clearAntiJumpConns()
    for _, conn in ipairs(antiJumpConns) do pcall(function() conn:Disconnect() end) end
    antiJumpConns = {}
end

local function setupAntiInfiniteJump(char)
    clearAntiJumpConns()
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    local inAir, airJumpCount = false, 0
    local stateConn = hum.StateChanged:Connect(function(_, newState)
        if not antiInfiniteJump then return end
        if newState == Enum.HumanoidStateType.Jumping then
            if inAir then
                airJumpCount = airJumpCount + 1
                warn("[防無限跳] 空中跳躍偵測，次數：" .. airJumpCount)
                game.Players.LocalPlayer:Kick("你差點被封了")
            else
                inAir = true; airJumpCount = 0
            end
        elseif newState == Enum.HumanoidStateType.Freefall then
            if not inAir then inAir = true; airJumpCount = 0 end
        elseif newState == Enum.HumanoidStateType.Landed
            or newState == Enum.HumanoidStateType.Running
            or newState == Enum.HumanoidStateType.RunningNoPhysics
            or newState == Enum.HumanoidStateType.Swimming then
            inAir = false; airJumpCount = 0
        end
    end)
    table.insert(antiJumpConns, stateConn)
end

local function watchGloveForCloud()
    task.spawn(function()
        local leaderstats = LocalPlayer:WaitForChild("leaderstats", 10)
        if not leaderstats then return end
        local gloveVal = leaderstats:WaitForChild("Glove", 10)
        if not gloveVal then return end

        local function onGloveChanged()
            local currentGlove = gloveVal.Value
            if currentGlove == "Cloud" then
                if not userManuallySet and antiInfiniteJump then
                    antiInfiniteJump    = false
                    autoDisabledByCloud = true
                    clearAntiJumpConns()
                    updateAntiJumpBtn()
                    print("[防無限跳] 偵測到 Cloud 手套，自動關閉")
                end
            else
                if autoDisabledByCloud then
                    antiInfiniteJump    = true
                    autoDisabledByCloud = false
                    local char = LocalPlayer.Character
                    if char then setupAntiInfiniteJump(char) end
                    updateAntiJumpBtn()
                    print("[防無限跳] 離開 Cloud 手套，自動重新開啟")
                end
            end
        end

        gloveVal.Changed:Connect(onGloveChanged)
        onGloveChanged()
    end)
end

watchGloveForCloud()

LocalPlayer.CharacterAdded:Connect(function(newChar)
    task.wait(0.5)
    if antiInfiniteJump then setupAntiInfiniteJump(newChar) end
end)
task.spawn(function()
    task.wait(1)
    local char = LocalPlayer.Character
    if char and antiInfiniteJump then setupAntiInfiniteJump(char) end
end)


-- 防無限跳功能（預設開啟，支援平板觸控）
-- ══════════════════════════════════════════
local antiInfiniteJump = true
local antiJumpConns = {}

local function clearAntiJumpConns()
    for _, conn in ipairs(antiJumpConns) do
        pcall(function() conn:Disconnect() end)
    end
    antiJumpConns = {}
end

local function setupAntiInfiniteJump(char)
    clearAntiJumpConns()

    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end

    local inAir = false        -- 是否在空中（第一跳後）
    local airJumpCount = 0     -- 空中期間額外偵測到的 Jumping 次數

    local stateConn = hum.StateChanged:Connect(function(_, newState)
        if not antiInfiniteJump then return end

        if newState == Enum.HumanoidStateType.Jumping then
            if inAir then
                -- 已在空中又偵測到 Jumping → 計數
                airJumpCount = airJumpCount + 1
                warn("[防無限跳] 空中跳躍偵測，次數：" .. airJumpCount)
                warn("[防無限跳] 空中跳躍，踢出！")
                game.Players.LocalPlayer:Kick("你差點被封了")
            else
                -- 正常第一跳，進入 inAir
                inAir = true
                airJumpCount = 0
            end

        elseif newState == Enum.HumanoidStateType.Freefall then
            -- 確保進入自由落體後 inAir = true
            if not inAir then
                inAir = true
                airJumpCount = 0
            end

        elseif newState == Enum.HumanoidStateType.Landed
            or newState == Enum.HumanoidStateType.Running
            or newState == Enum.HumanoidStateType.RunningNoPhysics
            or newState == Enum.HumanoidStateType.Swimming then
            -- 落地後重置
            inAir = false
            airJumpCount = 0
        end
    end)
    table.insert(antiJumpConns, stateConn)
end


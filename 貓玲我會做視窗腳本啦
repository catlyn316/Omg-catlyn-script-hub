-- 通用腳本按鈕函式（徽章/精通手套共用）
-- 用法：addScriptButton(父容器, "按鈕名", 順序, enablePlatform, "腳本網址")
--   enablePlatform = "y" → 按下時若防虛空未開，自動開啟
--   enablePlatform = "n" → 不影響防虛空狀態（預設）
-- ══════════════════════════════════════════
local function addScriptButton(parent, name, order, enablePlatform, url)
    local btn = createButton(name, order, parent, 40)
    btn.MouseButton1Click:Connect(function()
        if enablePlatform == "y" then
            enablePlatformIfNeeded()
        end
        loadstring(game:HttpGet(url))()
    end)
    return btn
end


local function runLoopBrightNoFogDeleteScreenshake()
    local Lighting = game:GetService("Lighting")
    task.spawn(function()
        while true do
            Lighting.Brightness        = 2
            Lighting.ClockTime         = 14
            Lighting.FogEnd            = 1000000
            Lighting.FogStart          = 1000000
            Lighting.GlobalShadows     = false
            Lighting.Ambient           = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient    = Color3.fromRGB(255, 255, 255)
            for _, effect in ipairs(Lighting:GetChildren()) do
                if effect:IsA("PostEffect") then
                    effect.Enabled = false
                end
            end
            task.wait(1)
        end
    end)

    local function deleteScreenshake(parent)
        for _, obj in ipairs(parent:GetDescendants()) do
            if (obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ModuleScript"))
            and obj.Name:lower():find("screenshake") then
                pcall(function() obj:Destroy() end)
            end
        end
    end
    pcall(function() deleteScreenshake(Workspace) end)
    pcall(function() deleteScreenshake(game:GetService("ReplicatedStorage")) end)
    pcall(function() deleteScreenshake(LocalPlayer) end)
end


local function cleanUp()
    if generatedPlatform  then generatedPlatform:Destroy(); generatedPlatform = nil end
    if autoSlapConnection then task.cancel(autoSlapConnection); autoSlapConnection = nil end
    if plateLockThread    then task.cancel(plateLockThread); plateLockThread = nil end
    autoSlap    = false
    plateLocked = false
    clearAntiJumpConns()
end

script.AncestryChanged:Connect(function(_, newParent)
    if not newParent then cleanUp() end
end)

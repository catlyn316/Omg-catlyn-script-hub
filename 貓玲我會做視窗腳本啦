-- 盤子：單擊傳送，雙擊切換固定追蹤
local plateLocked       = false
local plateLockThread   = nil
local plateLastClick    = 0
local PLATE_DCLICK_TIME = 0.4  -- 雙擊判定秒數

local function stopPlateLock()
    plateLocked = false
    if plateLockThread then
        task.cancel(plateLockThread)
        plateLockThread = nil
    end
    TPButtons[9].Text = "盤子(雙擊固定)"
end

local function startPlateLock()
    plateLocked     = true
    TPButtons[9].Text = "盤子(固定中🔒)"
    plateLockThread = task.spawn(function()
        while plateLocked do
            pcall(function()
                local plate = Workspace:FindFirstChild("Arena") and Workspace.Arena:FindFirstChild("Plate")
                local hrp   = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if plate and hrp then
                    -- 卡進盤子中心（Y 偏移 0 讓軀幹嵌入盤子）
                    hrp.CFrame = CFrame.new(plate.Position)
                end
            end)
            task.wait(0)  -- 每幀更新
        end
    end)
end

TPButtons[9].MouseButton1Click:Connect(function()
    local now = tick()
    local dt  = now - plateLastClick
    plateLastClick = now

    if dt <= PLATE_DCLICK_TIME then
        -- 雙擊：切換固定
        if plateLocked then
            stopPlateLock()
        else
            -- 先傳送過去再開始鎖定
            pcall(function()
                local plate = Workspace:FindFirstChild("Arena") and Workspace.Arena:FindFirstChild("Plate")
                local hrp   = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if plate and hrp then hrp.CFrame = CFrame.new(plate.Position) end
            end)
            startPlateLock()
        end
    else
        -- 單擊：只傳送，不鎖定
        if plateLocked then stopPlateLock() end
        pcall(function()
            local plate = Workspace:FindFirstChild("Arena") and Workspace.Arena:FindFirstChild("Plate")
            local hrp   = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if plate and hrp then hrp.CFrame = plate.CFrame end
        end)
    end
end)

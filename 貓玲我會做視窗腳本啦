local _visitedServers = {}
local _VISIT_COOLDOWN = 120

local function _markVisited(jobId)
    _visitedServers[jobId] = tick()
end
local function _isRecentlyVisited(jobId)
    local t = _visitedServers[jobId]
    if t and (tick() - t) < _VISIT_COOLDOWN then return true end
    return false
end
local function _cleanVisited()
    local now = tick()
    for id, t in pairs(_visitedServers) do
        if now - t >= _VISIT_COOLDOWN then _visitedServers[id] = nil end
    end
end

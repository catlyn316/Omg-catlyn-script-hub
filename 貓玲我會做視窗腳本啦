        auraLoop = task.spawn(function()
            while auraEnabled do
                task.wait(1)
                if not auraEnabled then break end
                local target=getNearestInRange(values.auraRange)
                if target and auraDetectedEvent then
                    local newArgs={}
                    for _,v in ipairs(auraDetectedArgs) do
                        local replaced=false
                        if typeof(v)=="Instance" then
                            if v:IsA("Player") and v~=player then table.insert(newArgs,target); replaced=true
                            elseif v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") and v~=player.Character then table.insert(newArgs,target.Character or v); replaced=true

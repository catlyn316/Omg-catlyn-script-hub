-- 改變所有玩家名
local changeNamesEnabled = false
local changeNamesConns   = {}

local function applyNameToChar(character)
    if character == LocalPlayer.Character then return end
    task.spawn(function()
        local head     = character:WaitForChild("Head", 5)
        if not head then return end
        local nametag  = head:WaitForChild("Nametag", 5)
        if not nametag then return end
        local labels   = nametag:WaitForChild("Labels", 5)
        if not labels then return end
        local topLabel = labels:WaitForChild("TopLabel", 5)
        if not topLabel then return end
        topLabel.Text  = "catlyn's helper"
    end)
end

local function applyNamesToAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            applyNameToChar(player.Character)
        end
    end
end

local function startChangeNames()
    applyNamesToAll()
    local c1 = Players.PlayerAdded:Connect(function(player)
        if not changeNamesEnabled then return end
        player.CharacterAdded:Connect(function(char)
            if changeNamesEnabled then task.wait(0.3); applyNameToChar(char) end
        end)
        if player.Character then task.wait(0.3); applyNameToChar(player.Character) end
    end)
    local charConns = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local cc = player.CharacterAdded:Connect(function(char)
                if changeNamesEnabled then task.wait(0.3); applyNameToChar(char) end
            end)
            table.insert(charConns, cc)
        end
    end
    changeNamesConns = {c1}
    for _, cc in ipairs(charConns) do table.insert(changeNamesConns, cc) end
    table.insert(changeNamesConns, { disconnect = function() changeNamesEnabled = false end })
    task.spawn(function()
        while changeNamesEnabled do task.wait(3); if changeNamesEnabled then applyNamesToAll() end end
    end)
end

local function stopChangeNames()
    for _, conn in ipairs(changeNamesConns) do
        pcall(function()
            if typeof(conn) == "RBXScriptConnection" then conn:Disconnect()
            elseif type(conn) == "table" and conn.disconnect then conn:disconnect() end
        end)
    end
    changeNamesConns = {}
end

local changeNamesBtn = createButton("改變玩家名: 關", 8, CommonButtonsScroll)
changeNamesBtn.MouseButton1Click:Connect(function()
    changeNamesEnabled  = not changeNamesEnabled
    changeNamesBtn.Text = changeNamesEnabled and "改變玩家名: 開" or "改變玩家名: 關"
    if changeNamesEnabled then startChangeNames() else stopChangeNames() end
end)


-- 改變所有玩家名（開關）
local changeNamesEnabled = false
local changeNamesConns = {}

local changeNamesBtn = createButton("改變玩家名: 關", 8, CommonButtonsScroll, 45)

local function applyNameToChar(character)
    -- 跳過自己
    if character == LocalPlayer.Character then return end
    task.spawn(function()
        -- 等待 Head 和 Nametag 載入
        local head = character:WaitForChild("Head", 5)
        if not head then return end
        local nametag = head:WaitForChild("Nametag", 5)
        if not nametag then return end
        local labels = nametag:WaitForChild("Labels", 5)
        if not labels then return end
        local topLabel = labels:WaitForChild("TopLabel", 5)
        if not topLabel then return end
        topLabel.Text = "catlyn's helper"
    end)
end

local function applyNamesToAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            applyNameToChar(player.Character)
        end
    end
end

local function startChangeNames()
    -- 套用到目前所有玩家
    applyNamesToAll()

    -- 新玩家加入 → 監聽其角色
    local c1 = Players.PlayerAdded:Connect(function(player)
        if not changeNamesEnabled then return end
        -- 監聽此玩家的每次角色重生
        player.CharacterAdded:Connect(function(char)
            if changeNamesEnabled then
                task.wait(0.3)
                applyNameToChar(char)
            end
        end)
        -- 如果玩家已有角色
        if player.Character then
            task.wait(0.3)
            applyNameToChar(player.Character)
        end
    end)

    -- 已在線玩家每次重生也要改
    local c2 = Players.PlayerRemoving:Connect(function() end) -- placeholder
    local charConns = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local cc = player.CharacterAdded:Connect(function(char)
                if changeNamesEnabled then
                    task.wait(0.3)
                    applyNameToChar(char)
                end
            end)
            table.insert(charConns, cc)
        end
    end

    changeNamesConns = { c1, c2 }
    for _, cc in ipairs(charConns) do
        table.insert(changeNamesConns, cc)
    end

    -- 持續輪詢確保名字不被遊戲重置（每3秒掃一次）
    local loopConn
    loopConn = task.spawn(function()
        while changeNamesEnabled do
            task.wait(3)
            if changeNamesEnabled then
                applyNamesToAll()
            end
        end
    end)
    table.insert(changeNamesConns, { disconnect = function()
        changeNamesEnabled = false -- 讓 while 自然結束
    end })
end

local function stopChangeNames()
    for _, conn in ipairs(changeNamesConns) do
        pcall(function()
            if typeof(conn) == "RBXScriptConnection" then
                conn:Disconnect()
            elseif type(conn) == "table" and conn.disconnect then
                conn:disconnect()
            end
        end)
    end
    changeNamesConns = {}
end

changeNamesBtn.MouseButton1Click:Connect(function()
    changeNamesEnabled = not changeNamesEnabled
    changeNamesBtn.Text = changeNamesEnabled and "改變玩家名: 開" or "改變玩家名: 關"
    if changeNamesEnabled then
        startChangeNames()
    else
        stopChangeNames()
    end
end)

